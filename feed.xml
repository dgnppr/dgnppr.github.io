---
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:content="http://purl.org/rss/1.0/modules/content/"
  xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.summary | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ "/feed.xml" | prepend: site.baseurl | prepend: site.url }}" rel="self" type="application/rss+xml"/>
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>
    <language>ko-KR</language>
    <managingEditor>{{ site.author }} ({{ site.author }})</managingEditor>
{% assign wiki_docs = site.concept | where: "public", true | sort: "updated" | reverse %}
{% for doc in wiki_docs limit: 100 %}
  {% unless doc.title == 'wiki' or doc.url == '/concept/' %}
    <item>
      <title>{{ doc.title | xml_escape }}</title>
      <link>{{ doc.url | prepend: site.baseurl | prepend: site.url }}</link>
      <guid isPermaLink="true">{{ doc.url | prepend: site.baseurl | prepend: site.url }}</guid>
      <pubDate>{{ doc.updated | default: doc.date | date_to_rfc822 }}</pubDate>
      <dc:creator>{{ site.author | xml_escape }}</dc:creator>
      {% if doc.summary and doc.summary != "" %}
      <description>{{ doc.summary | xml_escape }}</description>
      {% else %}
      <description>{{ doc.title | xml_escape }}</description>
      {% endif %}
      <content:encoded><![CDATA[{{ doc.content }}]]></content:encoded>
      {% assign doc_tags = doc.tag | split: ' ' %}
      {% for tag in doc_tags %}
        {% if tag != "" %}
      <category>{{ tag | xml_escape }}</category>
        {% endif %}
      {% endfor %}
    </item>
  {% endunless %}
{% endfor %}
{% for post in site.posts limit: 30 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | prepend: site.baseurl | prepend: site.url }}</link>
      <guid isPermaLink="true">{{ post.url | prepend: site.baseurl | prepend: site.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <dc:creator>{{ site.author | xml_escape }}</dc:creator>
      {% if post.summary and post.summary != "" %}
      <description>{{ post.summary | xml_escape }}</description>
      {% else %}
      <description>{{ post.title | xml_escape }}</description>
      {% endif %}
      <content:encoded><![CDATA[{{ post.content }}]]></content:encoded>
      {% assign post_tags = post.tag | split: ' ' %}
      {% for tag in post_tags %}
        {% if tag != "" %}
      <category>{{ tag | xml_escape }}</category>
        {% endif %}
      {% endfor %}
    </item>
{% endfor %}
  </channel>
</rss>
